    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Générateur de Planification de Jardin Méditerranéen | Imaginez Votre Espace</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:wght@700&display=swap');\n\n        :root {\n            --color-primary: #b46a3b; /* Copper-like */\n            --color-secondary: #e0d0c0; /* Warm beige */\n            --color-tertiary: #5a3c2b; /* Darker copper */\n            --color-background: #f7f2ed;\n            --color-text: #3a2b20;\n            --color-light-text: #6b5c50;\n            --color-border: rgba(180, 106, 59, 0.4);\n            --color-glass-bg: rgba(255, 255, 255, 0.6);\n            --color-glass-border: rgba(180, 106, 59, 0.2);\n            --shadow-subtle: 0 4px 12px rgba(0, 0, 0, 0.08);\n            --shadow-glass: 0 6px 20px rgba(0, 0, 0, 0.1), inset 0 0 0 1px var(--color-glass-border);\n            --border-radius: 12px;\n        }\n\n        body {\n            font-family: 'Montserrat', sans-serif;\n            line-height: 1.6;\n            color: var(--color-text);\n            background-color: var(--color-background);\n            margin: 0;\n            padding: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        header {\n            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-tertiary) 100%);\n            color: white;\n            padding: 40px 20px;\n            text-align: center;\n            width: 100%;\n            box-shadow: var(--shadow-subtle);\n            margin-bottom: 40px;\n        }\n\n        header h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 2.8em;\n            margin-bottom: 15px;\n            font-weight: 700;\n        }\n\n        header p {\n            font-size: 1.1em;\n            max-width: 800px;\n            margin: 0 auto;\n            font-weight: 300;\n        }\n\n        main {\n            display: grid;\n            grid-template-columns: 1fr;\n            gap: 40px;\n            width: 90%;\n            max-width: 1200px;\n            margin-bottom: 60px;\n        }\n\n        .panel {\n            background-color: var(--color-glass-bg);\n            backdrop-filter: blur(10px);\n            border-radius: var(--border-radius);\n            padding: 30px;\n            box-shadow: var(--shadow-glass);\n            border: 1px solid var(--color-glass-border);\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n\n        .panel h2 {\n            font-family: 'Playfair Display', serif;\n            color: var(--color-primary);\n            font-size: 1.8em;\n            margin-bottom: 15px;\n            border-bottom: 2px solid var(--color-primary);\n            padding-bottom: 10px;\n        }\n\n        .panel p {\n            font-size: 1em;\n            color: var(--color-light-text);\n        }\n\n        .form-group {\n            margin-bottom: 20px;\n        }\n\n        label {\n            display: block;\n            margin-bottom: 8px;\n            font-weight: 600;\n            color: var(--color-tertiary);\n            font-size: 0.95em;\n        }\n\n        input[type=\"text\"],\n        input[type=\"number\"],\n        select,\n        textarea {\n            width: calc(100% - 24px);\n            padding: 12px;\n            border: 1px solid var(--color-border);\n            border-radius: 8px;\n            font-family: 'Montserrat', sans-serif;\n            font-size: 1em;\n            background-color: var(--color-secondary);\n            color: var(--color-text);\n            transition: border-color 0.3s ease, box-shadow 0.3s ease;\n        }\n\n        input[type=\"text\"]:focus,\n        input[type=\"number\"]:focus,\n        select:focus,\n        textarea:focus {\n            border-color: var(--color-primary);\n            box-shadow: 0 0 0 3px rgba(180, 106, 59, 0.2);\n            outline: none;\n        }\n\n        textarea {\n            min-height: 100px;\n            resize: vertical;\n        }\n\n        button {\n            background-color: var(--color-primary);\n            color: white;\n            border: none;\n            padding: 14px 25px;\n            border-radius: 8px;\n            font-size: 1.1em;\n            font-weight: 600;\n            cursor: pointer;\n            transition: background-color 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;\n            box-shadow: var(--shadow-subtle);\n            width: 100%;\n            margin-top: 10px;\n        }\n\n        button:hover {\n            background-color: var(--color-tertiary);\n            transform: translateY(-2px);\n            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);\n        }\n\n        #tool-result {\n            margin-top: 30px;\n            background-color: var(--color-secondary);\n            padding: 25px;\n            border-radius: var(--border-radius);\n            border: 1px solid var(--color-border);\n            box-shadow: var(--shadow-subtle);\n            display: none; /* Hidden by default */\n        }\n\n        #tool-result h3 {\n            font-family: 'Playfair Display', serif;\n            color: var(--color-tertiary);\n            font-size: 1.6em;\n            margin-bottom: 20px;\n            text-align: center;\n        }\n\n        .result-section {\n            margin-bottom: 25px;\n        }\n\n        .result-section h4 {\n            font-size: 1.2em;\n            color: var(--color-primary);\n            margin-bottom: 10px;\n            border-bottom: 1px dashed var(--color-border);\n            padding-bottom: 5px;\n        }\n\n        .result-section ul {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n\n        .result-section li {\n            background-color: rgba(255, 255, 255, 0.7);\n            padding: 10px 15px;\n            border-radius: 6px;\n            margin-bottom: 8px;\n            border: 1px solid rgba(180, 106, 59, 0.1);\n            color: var(--color-text);\n            font-size: 0.95em;\n        }\n\n        .seo-section {\n            background-color: var(--color-text);\n            color: white;\n            padding: 50px 20px;\n            text-align: center;\n            width: 100%;\n            margin-top: 60px;\n            box-shadow: inset 0 5px 15px rgba(0, 0, 0, 0.2);\n        }\n\n        .seo-section h2 {\n            font-family: 'Playfair Display', serif;\n            font-size: 2.2em;\n            margin-bottom: 25px;\n            color: var(--color-secondary);\n        }\n\n        .seo-section p {\n            max-width: 900px;\n            margin: 0 auto 20px auto;\n            font-size: 0.95em;\n            line-height: 1.7;\n            color: var(--color-secondary);\n        }\n\n        .seo-section a {\n            color: var(--color-primary);\n            text-decoration: none;\n            font-weight: 600;\n        }\n\n        .seo-section a:hover {\n            text-decoration: underline;\n        }\n\n        @media (min-width: 768px) {\n            main {\n                grid-template-columns: 1fr 1fr;\n            }\n\n            .panel.full-width {\n                grid-column: span 2;\n            }\n\n            button {\n                width: auto;\n                min-width: 200px;\n            }\n            .form-group.action {\n                text-align: right;\n            }\n        }\n    </style>\n    <meta name=\"description\" content=\"Créez le jardin de vos rêves adapté au climat ensoleillé du sud de la France. Notre outil interactif vous guide dans la sélection de plantes résistantes, d&#x27;agencements harmonieux et de textures chaudes, pour un espace extérieur qui respire la douceur de vivre méditerranéenne.\">\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://generateur-de-planification-de-jardin-mediterraneen-1.onrender.com\">\n    <meta property=\"og:title\" content=\"Générateur de Planification de Jardin Méditerranéen\">\n    <meta property=\"og:description\" content=\"Créez le jardin de vos rêves adapté au climat ensoleillé du sud de la France. Notre outil interactif vous guide dans la sélection de plantes résistantes, d&#x27;agencements harmonieux et de textures chaudes, pour un espace extérieur qui respire la douceur de vivre méditerranéenne.\">\n    <meta property=\"og:url\" content=\"https://generateur-de-planification-de-jardin-mediterraneen-1.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Générateur de Planification de Jardin Méditerranéen\", \"description\": \"Créez le jardin de vos rêves adapté au climat ensoleillé du sud de la France. Notre outil interactif vous guide dans la sélection de plantes résistantes, d'agencements harmonieux et de textures chaudes, pour un espace extérieur qui respire la douceur de vivre méditerranéenne.\", \"url\": \"https://generateur-de-planification-de-jardin-mediterraneen-1.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"generateur-de-planification-de-jardin-mediterraneen-1\" data-runtime-mode=\"palette_generator\">\n    <header>\n        <h1>Votre Oasis Méditerranéenne, Conçue sur Mesure</h1>\n        <p>Créez le jardin de vos rêves adapté au climat ensoleillé du sud de la France. Notre outil interactif vous guide dans la sélection de plantes résistantes, d'agencements harmonieux et de textures chaudes, pour un espace extérieur qui respire la douceur de vivre méditerranéenne.</p>\n    </header>\n\n    <main>\n        <section class=\"panel\">\n            <h2>Imaginez Votre Espace</h2>\n            <p>Décrivez-nous votre futur jardin. Chaque détail compte pour sculpter une proposition qui vous ressemble, en harmonie avec le soleil généreux et les essences du Midi.</p>\n            <form id=\"tool-form\">\n                <div class=\"form-group\">\n                    <label for=\"location\">Votre département (ex: Bouches-du-Rhône, Var) :</label>\n                    <input type=\"text\" id=\"location\" placeholder=\"Ex: Hérault\" required>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"surface\">Surface approximative du jardin (en m²) :</label>\n                    <input type=\"number\" id=\"surface\" min=\"10\" max=\"5000\" value=\"100\" required>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"exposition\">Exposition principale du jardin :</label>\n                    <select id=\"exposition\" required>\n                        <option value=\"pleinsud\">Plein Sud (très ensoleillé)</option>\n                        <option value=\"estouest\">Est/Ouest (soleil mi-journée)</option>\n                        <option value=\"nord\">Nord (ombre ou mi-ombre)</option>\n                    </select>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"soil\">Type de sol (observé ou supposé) :</label>\n                    <select id=\"soil\" required>\n                        <option value=\"calcaire\">Calcaire (drainant, sec)</option>\n                        <option value=\"argileux\">Argileux (retient l'eau)</option>\n                        <option value=\"sableux\">Sableux (très drainant)</option>\n                        <option value=\"normal\">Normal/Standard</option>\n                    </select>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"preferences\">Vos préférences de style ou ambiances (ex: garrigue, provence, contemporain...) :</label>\n                    <textarea id=\"preferences\" placeholder=\"Ex: J'aime les couleurs chaudes, les odeurs d'aromates, un coin ombragé pour l'été.\"></textarea>\n                </div>\n                <div class=\"form-group action\">\n                    <button type=\"submit\" id=\"tool-submit\" data-affiliate-slot=\"generate_plan\">Générer mon plan de jardin</button>\n                </div>\n            </form>\n        </section>\n\n        <section class=\"panel full-width\">\n            <h2>Votre Plan Personnalisé</h2>\n            <p>Découvrez une proposition unique, inspirée par la richesse botanique de la Méditerranée et adaptée à vos envies. Ce plan est une suggestion pour vous aider à démarrer votre projet.</p>\n            <div id=\"tool-result\">\n                <h3 id=\"result-headline\">Votre Ébauche de Jardin Méditerranéen</h3>\n\n                <div class=\"result-section\">\n                    <h4>Sélection de Plantes Indigènes & Résistantes</h4>\n                    <ul id=\"result-plants\"></ul>\n                </div>\n\n                <div class=\"result-section\">\n                    <h4>Suggestions d'Agencement & Textures</h4>\n                    <ul id=\"result-layout\"></ul>\n                </div>\n\n                <div class=\"result-section\">\n                    <h4>Conseils Climat & Entretien</h4>\n                    <ul id=\"result-tips\"></ul>\n                </div>\n\n            </div>\n        </section>\n    </main>\n\n    <section class=\"seo-section\">\n        <h2>Créer un Jardin Méditerranéen en France : Guide Complet</h2>\n        <p>Envie d'aménager un <a href=\"#\" aria-label=\"jardin méditerranéen sec\">jardin méditerranéen sec</a>, résistant à la <a href=\"#\" aria-label=\"sécheresse plantes sud france\">sécheresse</a>, en Provence, en Occitanie ou sur la Côte d'Azur ? Notre générateur vous aide à concevoir un <a href=\"#\" aria-label=\"plan jardin méditerranéen\">plan de jardin méditerranéen</a> personnalisé. Découvrez les meilleures <a href=\"#\" aria-label=\"plantes méditerranéennes résistantes chaleur\">plantes méditerranéennes résistantes à la chaleur</a> et au manque d'eau, idéales pour un <a href=\"#\" aria-label=\"aménagement paysager climat méditerranéen\">aménagement paysager en climat méditerranéen</a>. Que vous cherchiez des idées pour un petit espace ou un grand domaine, notre outil propose des solutions adaptées à vos préférences de style, que ce soit une ambiance garrigue, un jardin provençal ou un design contemporain. Évitez le stress du choix des végétaux grâce à nos <a href=\"#\" aria-label=\"conseils jardinage méditerranéen\">conseils jardinage méditerranéen</a> et créez un oasis durable et esthétique. Simplifiez la <a href=\"#\" aria-label=\"conception jardin méditerranéen\">conception de votre jardin méditerranéen</a> dès aujourd'hui !</p>\n    </section>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(e) {\n            e.preventDefault();\n\n            const location = document.getElementById('location').value.toLowerCase();\n            const surface = parseInt(document.getElementById('surface').value);\n            const exposition = document.getElementById('exposition').value;\n            const soil = document.getElementById('soil').value;\n            const preferences = document.getElementById('preferences').value.toLowerCase();\n\n            let plants = [];\n            let layout = [];\n            let tips = [];\n\n            // Plant selection logic\n            if (exposition === 'pleinsud') {\n                plants.push(\"Lavande (Lavandula angustifolia) - pour son parfum et sa résistance.\");\n                plants.push(\"Romarin (Rosmarinus officinalis) - arbuste aromatique et structurant.\");\n                plants.push(\"Cistes (Cistus) - floraison généreuse, tolère les sols pauvres.\");\n                plants.push(\"Olivier (Olea europaea) - l'emblème de la Méditerranée.\");\n                plants.push(\"Cyprès de Provence (Cupressus sempervirens) - pour une structure verticale.\");\n            } else if (exposition === 'estouest') {\n                plants.push(\"Laurier-rose (Nerium oleander) - floraison éclatante.\");\n                plants.push(\"Arbousier (Arbutus unedo) - fruits décoratifs et résistance.\");\n                plants.push(\"Phlomis (Phlomis fruticosa) - feuillage gris, fleurs jaunes originales.\");\n                plants.push(\"Myrte (Myrtus communis) - feuillage persistant, fleurs délicates.\");\n            } else { // Nord ou mi-ombre\n                plants.push(\"Chèvrefeuille (Lonicera) - grimpante parfumée pour l'ombre.\");\n                plants.push(\"Fougères méditerranéennes (ex: Adiantum capillus-veneris) - pour les zones humides et ombragées.\");\n                plants.push(\"Pittosporum tobira - arbuste résistant à l'ombre et aux embruns.\");\n            }\n\n            if (soil === 'calcaire' || soil === 'sableux') {\n                plants.push(\"Thym (Thymus vulgaris) - couvre-sol aromatique.\");\n                plants.push(\"Sedum (Orpin) - succulente résistante à la sécheresse.\");\n                plants.push(\"Gaura (Gaura lindheimeri) - floraison légère et aérienne.\");\n            }\n            if (soil === 'argileux') {\n                plants.push(\"Grenadier (Punica granatum) - tolère les sols plus lourds.\");\n            }\n\n            // Additional plants based on preferences\n            if (preferences.includes('aromates') || preferences.includes('parfum')) {\n                plants.push(\"Sauge (Salvia officinalis) - feuillage décoratif et odeur.\");\n                plants.push(\"Fenouil (Foeniculum vulgare) - aspect sauvage et aérien.\");\n            }\n            if (preferences.includes('couleurs chaudes')) {\n                plants.push(\"Géranium vivace (Geranium sanguineum) - floraison rose/rouge.\");\n                plants.push(\"Santoline (Santolina chamaecyparissus) - feuillage gris, fleurs jaunes.\");\n            }\n            if (preferences.includes('ombre')) {\n                plants.push(\"Figuier (Ficus carica) - pour un coin gourmand et ombragé.\");\n            }\n            if (preferences.includes('cactus') || preferences.includes('succulentes')) {\n                plants.push(\"Agave (Agave americana) - pour un aspect graphique et moderne.\");\n                plants.push(\"Opuntia (Figuier de Barbarie) - attention aux épines !\");\n            }\n            if (preferences.includes('provençal')) {\n                plants.push(\"Buis (Buxus sempervirens) - pour les bordures et sculptures.\");\n                plants.push(\"Vigne (Vitis vinifera) - pour une pergola ombragée.\");\n            }\n\n\n            // Layout and textures suggestions\n            if (surface < 50) {\n                layout.push(\"Privilégiez des poteries en terre cuite de différentes tailles pour créer du volume.\");\n                layout.push(\"Utilisez un mur végétal avec des aromates pour maximiser l'espace.\");\n            } else if (surface < 200) {\n                layout.push(\"Créez des zones distinctes : un coin repas ombragé, un espace floral.\");\n                layout.push(\"Intégrez un chemin en gravier clair pour délimiter les parterres.\");\n            } else {\n                layout.push(\"Aménagez une large allée centrale en pierre locale.\");\n                layout.push(\"Prévoyez des massifs de grande envergure avec des arbres et arbustes structurants.\");\n                layout.push(\"Pensez à une petite fontaine ou un bassin pour le murmure de l'eau.\");\n            }\n\n            layout.push(\"Utilisez des galets ou graviers clairs comme paillage pour retenir l'humidité et apporter de la luminosité.\");\n            layout.push(\"Intégrez des roches et pierres naturelles pour un aspect garrigue.\");\n            layout.push(\"Pensez aux pergolas ou tonnelles en bois ou fer forgé, habillées de plantes grimpantes.\");\n            layout.push(\"Choisissez des mobiliers de jardin en fer forgé, bois naturel ou résine tressée aux teintes chaudes.\");\n\n\n            // Climate and maintenance tips\n            tips.push(\"Arrosez abondamment mais rarement, de préférence le soir ou tôt le matin.\");\n            tips.push(\"Paillez généreusement les pieds des plantes pour conserver l'humidité du sol.\");\n            tips.push(\"Privilégiez les plantes adaptées au climat local pour minimiser l'entretien.\");\n            tips.push(\"Installez un système d'arrosage goutte à goutte pour une gestion efficace de l'eau.\");\n            tips.push(\"Taillez les arbustes après la floraison pour favoriser la densification.\");\n            tips.push(\"Envisagez la récupération d'eau de pluie pour l'arrosage.\");\n\n            // Display results\n            document.getElementById('result-plants').innerHTML = plants.map(item => `<li>${item}</li>`).join('');\n            document.getElementById('result-layout').innerHTML = layout.map(item => `<li>${item}</li>`).join('');\n            document.getElementById('result-tips').innerHTML = tips.map(item => `<li>${item}</li>`).join('');\n\n            document.getElementById('tool-result').style.display = 'block';\n            document.getElementById('tool-result').scrollIntoView({ behavior: 'smooth' });\n        });\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AF